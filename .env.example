# API Keys
# Google AI Studio Gemini API keys may begin with either AIzaSy... or AQ....
# The app accepts either GEMINI_API_KEY or GOOGLE_API_KEY.
GEMINI_API_KEY=your_gemini_api_key_here
USER_API_KEY=your_user_api_key_here
DEFAULT_GOOGLE_MODEL=gemini-2.5-flash

# Phoenix Configuration
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces


# Gradio Configuration
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# Optional alias if you prefer the Google GenAI SDK naming.
# GOOGLE_API_KEY=your_gemini_api_key_here
